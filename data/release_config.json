{
  "version": "0.9-local-final-candidate",
  "disclaimer": "本作是非商业同人/本地原型游戏，用于《猫眼之后》九夜随机伪人辨识玩法验证。角色名与乐队设定仅作为同人语境参考，未获得官方授权，不代表原作或权利方立场。发布或分发时请保留此声明，并替换任何不适合公开发布的素材与文本。",
  "llm": {
    "optional": true,
    "backend_url": "http://127.0.0.1:8787/v1/dialogue",
    "env_example": ".env.example",
    "required_when_enabled": [
      "LLM_API_KEY"
    ],
    "optional_env": [
      "LLM_BASE_URL",
      "LLM_MODEL"
    ],
    "fallback": "未配置 LLM_API_KEY、后端未启动或请求失败时，Godot/后端会使用本地兜底文本；后端不决定真相，只负责角色表演。"
  },
  "release_checks": [
    "python tools/audit_project.py",
    "godot --headless --path D:\\game --script res://scripts/SmokeTest.gd",
    "godot --headless --path D:\\game --script res://scripts/FullRunAudit.gd",
    "godot --headless --path D:\\game --script res://scripts/BalanceAudit.gd",
    "python -m backend.smoke_test",
    "powershell -ExecutionPolicy Bypass -File tools\\build_release.ps1 -SkipExport"
  ]
}
